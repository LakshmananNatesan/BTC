"""
Crypto transaction ingestion job.

Reads raw transaction files from the S3 raw zone, applies schema
enforcement + data quality rules, deduplicates, and writes partitioned
Parquet to the S3 processed zone for Snowflake to load via COPY INTO.

Run locally:
    spark-submit ingest_transactions.py \
        --input s3a://your-bucket/raw/crypto_transactions/ \
        --output s3a://your-bucket/processed/crypto_transactions/ \
        --process-date 2026-07-03
"""

import argparse
import sys

from pyspark.sql import SparkSession, DataFrame
from pyspark.sql import functions as F
from pyspark.sql.types import (
    StructType, StructField, StringType, DoubleType, TimestampType, LongType
)

# ---------------------------------------------------------------------------
# Schema — enforced on read so malformed rows fail fast instead of silently
# coercing into the wrong type downstream.
# ---------------------------------------------------------------------------
RAW_SCHEMA = StructType([
    StructField("Transaction_ID",     StringType(),    False),
    StructField("Sender_Address",     StringType(),    True),
    StructField("Receiver_Address",   StringType(),    True),
    StructField("Amount",             DoubleType(),    True),
    StructField("Transaction_Fee",    DoubleType(),    True),
    StructField("Timestamp",          TimestampType(), True),
    StructField("Block_ID",           StringType(),    True),
    StructField("Mining_Pool",        StringType(),    True),
    StructField("Currency",           StringType(),    True),
    StructField("Transaction_Type",   StringType(),    True),
    StructField("Transaction_Status", StringType(),    True),
    StructField("Gas_Price_Gwei",     DoubleType(),    True),
])

VALID_STATUSES = {"success", "failed", "pending"}


def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument("--input", required=True, help="S3 raw zone path")
    parser.add_argument("--output", required=True, help="S3 processed zone path")
    parser.add_argument("--process-date", required=True, help="YYYY-MM-DD, used for partition + rejects path")
    parser.add_argument("--rejects-path", default=None, help="Optional path to write rejected rows for inspection")
    return parser.parse_args()


def read_raw(spark: SparkSession, input_path: str) -> DataFrame:
    """Read raw CSV with schema enforcement. Bad rows go to _corrupt_record
    instead of crashing the job or silently nulling out."""
    return (
        spark.read
        .option("header", "true")
        .option("mode", "PERMISSIVE")
        .option("columnNameOfCorruptRecord", "_corrupt_record")
        .schema(RAW_SCHEMA.add("_corrupt_record", StringType()))
        .csv(input_path)
    )


def clean_and_validate(df: DataFrame):
    """
    Apply data quality rules. Returns (clean_df, rejected_df) so bad rows
    are quarantined for inspection rather than silently dropped.
    """
    # Normalize string columns: trim whitespace, lowercase status/type for
    # consistent grouping downstream.
    df = (
        df
        .withColumn("Transaction_ID", F.trim(F.col("Transaction_ID")))
        .withColumn("Sender_Address", F.trim(F.col("Sender_Address")))
        .withColumn("Receiver_Address", F.trim(F.col("Receiver_Address")))
        .withColumn("Currency", F.upper(F.trim(F.col("Currency"))))
        .withColumn("Transaction_Type", F.lower(F.trim(F.col("Transaction_Type"))))
        .withColumn("Transaction_Status", F.lower(F.trim(F.col("Transaction_Status"))))
        .withColumn("Mining_Pool", F.trim(F.col("Mining_Pool")))
    )

    # Dedupe on Transaction_ID, keeping the most recent Timestamp if the
    # same tx_id appears more than once (e.g. retry writes upstream).
    from pyspark.sql.window import Window
    dedupe_window = Window.partitionBy("Transaction_ID").orderBy(F.col("Timestamp").desc())
    df = (
        df.withColumn("_row_num", F.row_number().over(dedupe_window))
        .filter(F.col("_row_num") == 1)
        .drop("_row_num")
    )

    # Build a single "reject reason" column instead of dropping silently —
    # each rule appends its own tag so multi-reason rejects are visible.
    reject_reasons = []

    def add_reason(condition, message):
        reject_reasons.append(F.when(condition, F.lit(message)))

    add_reason(F.col("_corrupt_record").isNotNull(), "malformed_row")
    add_reason(F.col("Transaction_ID").isNull() | (F.col("Transaction_ID") == ""), "missing_tx_id")
    add_reason(F.col("Timestamp").isNull(), "missing_timestamp")
    add_reason(F.col("Amount").isNull() | (F.col("Amount") < 0), "invalid_amount")
    add_reason(F.col("Transaction_Fee") < 0, "negative_fee")
    add_reason(~F.col("Transaction_Status").isin(*VALID_STATUSES) & F.col("Transaction_Status").isNotNull(),
               "invalid_status")
    add_reason(F.col("Currency").isNull() | (F.col("Currency") == ""), "missing_currency")

    df = df.withColumn(
        "_reject_reason",
        F.array_join(F.array(*[F.coalesce(r, F.lit(None)) for r in reject_reasons]).cast("array<string>"), ",")
    )
    # array_join skips nulls automatically only in Spark 3.4+; guard for older versions:
    df = df.withColumn(
        "_reject_reason",
        F.when(F.col("_reject_reason") == "", None).otherwise(F.col("_reject_reason"))
    )

    clean_df = df.filter(F.col("_reject_reason").isNull()).drop("_corrupt_record", "_reject_reason")
    rejected_df = df.filter(F.col("_reject_reason").isNotNull())

    return clean_df, rejected_df


def add_partition_columns(df: DataFrame) -> DataFrame:
    """Derive the date partition from Timestamp so downstream S3/Snowflake
    loads only scan the days that actually changed."""
    return df.withColumn("dt", F.to_date(F.col("Timestamp")))


def write_processed(df: DataFrame, output_path: str):
    (
        df.repartition("dt")  # avoid a flood of tiny files per partition
        .write
        .mode("overwrite")
        .partitionBy("dt")
        .option("compression", "snappy")
        .parquet(output_path)
    )


def main():
    args = parse_args()

    spark = (
        SparkSession.builder
        .appName("crypto-transaction-ingestion")
        .config("spark.sql.session.timeZone", "UTC")
        .getOrCreate()
    )

    raw_df = read_raw(spark, args.input)
    raw_count = raw_df.count()

    clean_df, rejected_df = clean_and_validate(raw_df)
    clean_df = add_partition_columns(clean_df)

    clean_count = clean_df.count()
    rejected_count = rejected_df.count()

    write_processed(clean_df, args.output)

    if args.rejects_path:
        rejected_df.write.mode("append").option("compression", "snappy") \
            .parquet(f"{args.rejects_path}/dt={args.process_date}")

    reject_rate = rejected_count / raw_count if raw_count else 0
    print(f"[ingest] raw={raw_count} clean={clean_count} rejected={rejected_count} "
          f"reject_rate={reject_rate:.2%}")

    # Fail the job loudly if data quality drops below threshold — this is
    # what feeds your GitHub Actions pipeline's pass/fail signal upstream
    # of dbt even running.
    if reject_rate > 0.05:
        print(f"[ingest] ERROR: reject rate {reject_rate:.2%} exceeds 5% threshold", file=sys.stderr)
        sys.exit(1)

    spark.stop()


if __name__ == "__main__":
    main()
