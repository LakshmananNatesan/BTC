-- Incremental merge: on every run, only process rows that are new or
-- changed since the last run (filtered on transaction_date), then MERGE
-- them into the target table instead of rebuilding the whole history.
-- On a 2M+ row/day table, full-refresh would mean re-scanning and
-- re-writing everything on every single run — this is the dbt-side half
-- of the "reduced compute" story (the Snowflake COPY INTO PATTERN clause
-- is the other half, one layer upstream).

{{
    config(
        materialized='incremental',
        unique_key='transaction_id',
        incremental_strategy='merge',
        on_schema_change='fail',
        contract={'enforced': true},
        cluster_by=['transaction_date'],
    )
}}

with transactions as (

    select * from {{ ref('stg_crypto_transactions') }}

    {% if is_incremental() %}
    where transaction_date >= (select dateadd('day', -3, max(transaction_date)) from {{ this }})
    {% endif %}

),

currency_lookup as (

    select * from {{ ref('seed_supported_currencies') }}

),

final as (

    select
        t.transaction_id,
        t.sender_address,
        t.receiver_address,
        t.amount,
        t.transaction_fee,
        t.transaction_timestamp,
        t.transaction_date,
        t.block_id,
        t.mining_pool,
        t.currency,
        c.currency_name,
        c.is_evm_chain,
        t.transaction_type,
        t.transaction_status,
        case when c.is_evm_chain then t.gas_price_gwei else null end as gas_price_gwei,
        t._loaded_at

    from transactions t
    left join currency_lookup c
        on t.currency = c.currency_code

)

select * from final
